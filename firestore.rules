rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read of model snapshots; writes only via the Admin SDK (publisher).
    match /snapshots/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
