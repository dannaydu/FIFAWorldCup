rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read of model snapshots; writes only via the Admin SDK (publisher).
    match /snapshots/{doc} {
      allow read: if true;
      allow write: if false;
    }
    // Each signed-in user owns their fantasy card.
    match /fantasy/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
